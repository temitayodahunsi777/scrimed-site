{
  "name": "scrimed-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/clean-generated-cache.mjs",
    "build": "node scripts/check-generated-integrity.mjs && next build",
    "start": "next start",
    "integrity": "node scripts/check-generated-integrity.mjs",
    "lint": "eslint .",
    "smoke:agent-workspace": "node scripts/agent-workspace-authenticated-smoke.mjs",
    "pretypecheck": "node scripts/clean-generated-cache.mjs",
    "typecheck": "node scripts/check-generated-integrity.mjs && tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.7",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
